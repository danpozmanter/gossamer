/*
 * File read/write — text and JSON.
 *
 * Uses `std::fs` for filesystem primitives and
 * `std::encoding::json` for structured payloads. Every call
 * returns a `Result<T, io::Error>` and is `?`-propagated.
 *
 * Run:
 *     gos run examples/file_io.gos
 */

use std::encoding::json
use std::errors
use std::fs
use std::io
use std::path

fn main() -> Result<(), errors::Error> {
    let dir = "/tmp/gossamer-file-io-demo"
    let text_path = path::join(&dir, &"greeting.txt")
    let json_path = path::join(&dir, &"settings.json")

    fs::create_dir_all(&dir).map_err(|e| errors::wrap(e, "mkdir"))?

    // --- text ---
    fs::write(&text_path, &"hello, gossamer\n")
        .map_err(|e| errors::wrap(e, "write text"))?
    let contents = fs::read_to_string(&text_path)
        .map_err(|e| errors::wrap(e, "read text"))?
    println!("read {} bytes: {}", contents.len(), contents.trim())

    // --- JSON ---
    let features: [json::Value] = [
        json::Value::String("http"),
        json::Value::String("tls"),
    ]
    let payload = json::Value::object([
        ("port", json::Value::Int(8080)),
        ("addr", json::Value::String("0.0.0.0")),
        ("features", json::Value::Array(features)),
    ])
    let rendered = json::render(&payload)
    fs::write(&json_path, &rendered)
        .map_err(|e| errors::wrap(e, "write json"))?

    let parsed_text = fs::read_to_string(&json_path)
        .map_err(|e| errors::wrap(e, "read json"))?
    let parsed = json::parse(&parsed_text)
        .map_err(|e| errors::wrap(e, "parse json"))?
    println!("parsed json: {}", json::render(&parsed))

    fs::remove_all(&dir).map_err(|e| errors::wrap(e, "cleanup"))?
    Ok(())
}
