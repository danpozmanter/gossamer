/*
 * Word counting — split a sentence on ASCII whitespace and
 * tally tokens.
 *
 * Walks the input by byte index and emits each non-whitespace
 * run as one token. Returns the token count plus the total
 * character count. Each helper is pure; the caller binds with
 * `let`.
 */

fn is_space(b: i64) -> bool {
    b == 32 || b == 9 || b == 10 || b == 13
}

struct Stats {
    chars: i64,
    words: i64,
}

fn analyse(text: &String) -> Stats {
    let mut chars: i64 = 0
    let mut words: i64 = 0
    let mut in_token = false
    for byte in text.as_bytes().iter() {
        let b = *byte as i64
        chars += 1
        if is_space(b) {
            in_token = false
        } else if !in_token {
            words += 1
            in_token = true
        }
    }
    Stats { chars: chars, words: words }
}

fn main() {
    let inputs = [
        "hello world",
        "the quick brown fox jumps over the lazy dog",
        "   leading and trailing   ",
        "one\ttwo\nthree four",
        "",
    ]
    for s in inputs {
        let stats = analyse(&s)
        println!("chars={}, words={}: {}", stats.chars, stats.words, s)
    }
}
