# generated by gos for {{ project_id }} -- fingerprint {{ fingerprint_hex }}
# DO NOT EDIT. Regenerated when `[rust-bindings]` changes.
[package]
name = "gos-runner-{{ fingerprint_hex }}"
version = "0.0.0"
edition = "2024"
publish = false

[[bin]]
name = "gos-runner"
path = "main.rs"

[[bin]]
name = "gos-sigs-dump"
path = "sigs_dump.rs"

[profile.dev]
opt-level = 0
debug = true

[profile.release]
opt-level = 3
lto = "thin"
codegen-units = 1
strip = "debuginfo"

[dependencies]
gossamer-cli     = { path = '{{ gossamer_root }}/crates/gossamer-cli' }
gossamer-binding = { path = '{{ gossamer_root }}/crates/gossamer-binding' }
{{#each bindings}}
{{ this.cargo_dep_line }}
{{/each}}
