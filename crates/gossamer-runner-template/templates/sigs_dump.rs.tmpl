fn type_to_json(t: &gossamer_binding::Type) -> String {
    use gossamer_binding::Type as T;
    match t {
        T::Unit => "{\"kind\":\"unit\"}".to_string(),
        T::Bool => "{\"kind\":\"bool\"}".to_string(),
        T::I64 => "{\"kind\":\"i64\"}".to_string(),
        T::F64 => "{\"kind\":\"f64\"}".to_string(),
        T::Char => "{\"kind\":\"char\"}".to_string(),
        T::String => "{\"kind\":\"string\"}".to_string(),
        T::Tuple(ts) => {
            let inner: Vec<String> = ts.iter().map(type_to_json).collect();
            format!("{{\"kind\":\"tuple\",\"items\":[{}]}}", inner.join(","))
        }
        T::Vec(inner) => format!("{{\"kind\":\"vec\",\"of\":{}}}", type_to_json(inner)),
        T::Option(inner) => format!("{{\"kind\":\"option\",\"of\":{}}}", type_to_json(inner)),
        T::Result(ok, err) => format!(
            "{{\"kind\":\"result\",\"ok\":{},\"err\":{}}}",
            type_to_json(ok),
            type_to_json(err)
        ),
        T::Opaque(name) => format!("{{\"kind\":\"opaque\",\"name\":{}}}", json_string(name)),
        T::Any => "{\"kind\":\"any\"}".to_string(),
    }
}

fn json_string(s: &str) -> String {
    let mut out = String::with_capacity(s.len() + 2);
    out.push('"');
    for ch in s.chars() {
        match ch {
            '"' => out.push_str("\\\""),
            '\\' => out.push_str("\\\\"),
            '\n' => out.push_str("\\n"),
            '\r' => out.push_str("\\r"),
            '\t' => out.push_str("\\t"),
            c if (c as u32) < 0x20 => out.push_str(&format!("\\u{:04x}", c as u32)),
            c => out.push(c),
        }
    }
    out.push('"');
    out
}

fn main() {
    {{#each bindings}}
    {{ this.crate_name_ident }}::__bindings_force_link();
    {{/each}}

    let mut modules_json: Vec<String> = Vec::new();
    for module in gossamer_binding::modules() {
        let mut items_json: Vec<String> = Vec::new();
        for item in module.items {
            let params: Vec<String> = item.signature.params.iter().map(type_to_json).collect();
            items_json.push(format!(
                "{{\"name\":{},\"doc\":{},\"params\":[{}],\"ret\":{}}}",
                json_string(item.name),
                json_string(item.doc),
                params.join(","),
                type_to_json(&item.signature.ret),
            ));
        }
        modules_json.push(format!(
            "{{\"path\":{},\"doc\":{},\"items\":[{}]}}",
            json_string(module.path),
            json_string(module.doc),
            items_json.join(","),
        ));
    }

    println!("{{\"modules\":[{}]}}", modules_json.join(","));
}
